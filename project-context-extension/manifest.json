{
  "manifest_version": 3,
  "name": "Project Context Bridge",
  "version": "1.2.0",
  "description": "Recarga automática de Google AI Studio al sincronizar contexto local con validación de estado y visualización de conexión.",
  "permissions": [
    "tabs",
    "action"
  ],
  "action": {
    "default_title": "Project Context Bridge"
  },
  "host_permissions": [
    "https://aistudio.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["content.js"]
    }
  ]
}
